ANTHROPIC_API_KEY=your_api_key_here
PORT=3000

# Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/callback
SESSION_SECRET=your_random_session_secret_here

# Discogs (optional — enables real track data for Time Machine; get a token at discogs.com/settings/developers)
DISCOGS_TOKEN=your_discogs_token_here

# Apple Music (optional — leave blank to disable Apple Music login)
# Get these from https://developer.apple.com → Certificates, IDs & Profiles → Keys
APPLE_TEAM_ID=your_10_char_team_id
APPLE_KEY_ID=your_10_char_key_id
# Paste your .p8 private key contents with literal \n for newlines:
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----"
